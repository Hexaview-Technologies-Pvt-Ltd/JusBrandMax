# Your Anthropic API key — required for live Brand Visibility reports (default engine).
# jusBrandMax is bring-your-own-key: this value never leaves your machine.
ANTHROPIC_API_KEY=

# Optional — measure non-Claude engines (provider: "openai" in brand.config.json).
# Works with OpenAI, OpenRouter, Together, Groq, or a local/internal OpenAI-compatible
# server (set OPENAI_BASE_URL, e.g. http://localhost:11434/v1 for Ollama).
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
